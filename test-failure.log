        halalRestaurantsPage();
        return;
      }
      if (view === 'public-toilets') {
        publicToiletsPage();
        return;
      }
      if (view === 'car-rental') {
        carRentalPage();
        return;
      }
      if (view === 'public-transport') {
        publicTransportPage();
        return;
      }
      if (view === 'taxi-services') {
        taxiPage();
        return;
